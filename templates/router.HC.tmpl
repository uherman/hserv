//
// Lookup order for a request path `/a/b`:
//   1. Page:            $pages_dir/a/b/index.html
//   2. Public asset:    $public_dir/a/b
//   3. Page-local file: $pages_dir/a/b
//   4. 404
//
// Special cases:
//   - "/" resolves to $pages_dir/index.html
//   - "/favicon.ico" falls back to $public_dir/favicon.{png,svg,jpg,jpeg,gif,webp}
//     when no literal favicon.ico is present.

I64 _TryFaviconFallback(I32 fd, U8 *request_path)
{
    U8 *exts[6];
    exts[0] = "png"; exts[1] = "svg"; exts[2] = "jpg";
    exts[3] = "jpeg"; exts[4] = "gif"; exts[5] = "webp";

    U8 fav_path[1024];
    I64 i;
    for (i = 0; i < 6; i++) {
        snprintf(fav_path, sizeof(fav_path), "$public_dir/favicon.%s", exts[i]);
        if (TryServeFile(fd, fav_path, ContentTypeFor(fav_path))) {
            LogInfo("200 %s -> %s", request_path, fav_path);
            return 1;
        }
    }
    return 0;
}

U0 Route(I32 fd, U8 *path)
{
