    NormalizePath(path, norm, sizeof(norm));

    U8 page_path[1024];
    if (MatchRoute(norm, "/")) {
        snprintf(page_path, sizeof(page_path), "$pages_dir/index.html");
    } else {
        snprintf(page_path, sizeof(page_path), "$pages_dir%s/index.html", norm);
    }
    if (TryServeFile(fd, page_path, "text/html; charset=utf-8")) {
        LogInfo("200 %s -> %s", path, page_path);
        return;
    }

    if (!MatchRoute(norm, "/")) {
        U8 public_path[1024];
        snprintf(public_path, sizeof(public_path), "$public_dir%s", norm);
        if (TryServeFile(fd, public_path, ContentTypeFor(norm))) {
            LogInfo("200 %s -> %s", path, public_path);
            return;
        }

        U8 local_path[1024];
        snprintf(local_path, sizeof(local_path), "$pages_dir%s", norm);
        if (TryServeFile(fd, local_path, ContentTypeFor(norm))) {
            LogInfo("200 %s -> %s", path, local_path);
            return;
        }
    }

    if (MatchRoute(norm, "/favicon.ico") && _TryFaviconFallback(fd, path)) return;

    LogWarn("404 %s", path);
    NotFoundResponse(fd);
}
